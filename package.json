{
  "name": "crateforge",
  "productName": "CrateForge",
  "version": "0.1.0",
  "description": "Library manager e utility di manutenzione per DJ. Compatibile con Rekordbox. Sviluppato da TX-Breaker in collaborazione con Rekordbox DJ Italia Group.",
  "author": "TX-Breaker",
  "license": "UNLICENSED",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "test": "node scripts/run-vitest.cjs run",
    "test:watch": "node scripts/run-vitest.cjs",
    "typecheck": "tsc --build",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "better-sqlite3": "12.2.0",
    "chardet": "2.0.0",
    "clsx": "2.1.1",
    "exceljs": "4.4.0",
    "fast-xml-parser": "4.5.0",
    "iconv-lite": "0.6.3",
    "lucide-react": "0.468.0",
    "music-metadata": "10.6.4",
    "tailwind-merge": "2.5.5",
    "xmlbuilder2": "3.1.1"
  },
  "devDependencies": {
    "@electron/rebuild": "3.7.1",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.6",
    "@types/better-sqlite3": "7.6.12",
    "@types/node": "22.10.2",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "class-variance-authority": "0.7.1",
    "electron": "33.2.1",
    "electron-builder": "25.1.8",
    "electron-vite": "2.3.0",
    "postcss": "8.4.49",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "1.0.7",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.8"
  }
}
